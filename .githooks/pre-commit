#!/usr/bin/env bash
# Runs before every commit — blocks if secrets are detected in staged files.

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo "🔒 Security check: scanning staged files for secrets..."

FOUND=0

# Patterns that look like real secrets (value assigned, not a placeholder)
SECRET_PATTERNS=(
  'GEMINI_API_KEY\s*=\s*[A-Za-z0-9_.\-]{20,}'
  'ANTHROPIC_API_KEY\s*=\s*sk-ant-[A-Za-z0-9\-]{20,}'
  'OPENAI_API_KEY\s*=\s*sk-[A-Za-z0-9]{20,}'
  'AWS_SECRET_ACCESS_KEY\s*=\s*[A-Za-z0-9/+]{30,}'
  'AWS_ACCESS_KEY_ID\s*=\s*AKIA[A-Z0-9]{16}'
  'STRIPE_SECRET_KEY\s*=\s*sk_(live|test)_[A-Za-z0-9]{20,}'
  'DATABASE_URL\s*=\s*postgres://[^ ]+'
  'SECRET_KEY\s*=\s*[A-Za-z0-9_.\-]{16,}'
  'password\s*=\s*[^\$\{][^\s]{8,}'
  'BEGIN (RSA|EC|OPENSSH) PRIVATE KEY'
  'ghp_[A-Za-z0-9]{36}'       # GitHub personal access token
  'gho_[A-Za-z0-9]{36}'       # GitHub OAuth token
)

# Files that should NEVER be committed
BLOCKED_FILES=(
  '\.env$'
  '\.env\.(local|production|staging|development)$'
  '.*_rsa$'
  '.*_dsa$'
  '.*_ecdsa$'
  '.*_ed25519$'
  '\.pem$'
  '\.p12$'
  '\.pfx$'
  'stocker\.db$'
  '\.sqlite$'
  '\.sqlite3$'
)

# Check for blocked filenames in staged files
while IFS= read -r file; do
  for pattern in "${BLOCKED_FILES[@]}"; do
    if echo "$file" | grep -qE "$pattern"; then
      echo -e "${RED}✗ BLOCKED FILE: $file matches sensitive file pattern '$pattern'${NC}"
      FOUND=1
    fi
  done
done < <(git diff --cached --name-only)

# Check staged file contents for secret patterns
while IFS= read -r file; do
  # Skip binary files
  if git show ":$file" | file - | grep -qE 'binary|image|executable'; then
    continue
  fi

  # Skip template/example files from content scan
  if echo "$file" | grep -qE '\.(example|sample|template)$'; then
    continue
  fi

  for pattern in "${SECRET_PATTERNS[@]}"; do
    if git show ":$file" | grep -qE "$pattern"; then
      echo -e "${RED}✗ SECRET DETECTED in $file — pattern: $pattern${NC}"
      FOUND=1
    fi
  done
done < <(git diff --cached --name-only)

if [ "$FOUND" -eq 1 ]; then
  echo ""
  echo -e "${RED}╔══════════════════════════════════════════════╗${NC}"
  echo -e "${RED}║  COMMIT BLOCKED — secrets detected above.   ║${NC}"
  echo -e "${RED}║  Remove them, then commit again.            ║${NC}"
  echo -e "${RED}╚══════════════════════════════════════════════╝${NC}"
  exit 1
fi

echo -e "${GREEN}✓ No secrets detected — safe to commit.${NC}"
exit 0
