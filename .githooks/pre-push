#!/usr/bin/env bash
# Runs before every push — final safety check across ALL committed files.

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m'

echo "🔒 Pre-push security scan: checking all tracked files for secrets..."

FOUND=0

SECRET_PATTERNS=(
  'GEMINI_API_KEY\s*=\s*[A-Za-z0-9_.\-]{20,}'
  'ANTHROPIC_API_KEY\s*=\s*sk-ant-[A-Za-z0-9\-]{20,}'
  'OPENAI_API_KEY\s*=\s*sk-[A-Za-z0-9]{20,}'
  'AWS_SECRET_ACCESS_KEY\s*=\s*[A-Za-z0-9/+]{30,}'
  'AWS_ACCESS_KEY_ID\s*=\s*AKIA[A-Z0-9]{16}'
  'STRIPE_SECRET_KEY\s*=\s*sk_(live|test)_[A-Za-z0-9]{20,}'
  'DATABASE_URL\s*=\s*postgres://[^ ]+'
  'SECRET_KEY\s*=\s*[A-Za-z0-9_.\-]{16,}'
  'BEGIN (RSA|EC|OPENSSH) PRIVATE KEY'
  'ghp_[A-Za-z0-9]{36}'
  'gho_[A-Za-z0-9]{36}'
)

BLOCKED_FILES=(
  '\.env$'
  '\.env\.(local|production|staging|development)$'
  '.*_rsa$'
  '.*_dsa$'
  '.*_ecdsa$'
  '.*_ed25519$'
  '\.pem$'
  '\.p12$'
  '\.pfx$'
  'stocker\.db$'
  '\.sqlite$'
  '\.sqlite3$'
)

# Scan every file currently tracked in the repo
while IFS= read -r file; do
  # Check filename itself
  for pattern in "${BLOCKED_FILES[@]}"; do
    if echo "$file" | grep -qE "$pattern"; then
      echo -e "${RED}✗ BLOCKED FILE in repo: $file${NC}"
      FOUND=1
    fi
  done

  # Skip template/example files and binaries from content scan
  if echo "$file" | grep -qE '\.(example|sample|template)$'; then
    continue
  fi
  if git show "HEAD:$file" 2>/dev/null | file - | grep -qE 'binary|image|executable'; then
    continue
  fi

  for pattern in "${SECRET_PATTERNS[@]}"; do
    if git show "HEAD:$file" 2>/dev/null | grep -qE "$pattern"; then
      echo -e "${RED}✗ SECRET DETECTED in $file — pattern: $pattern${NC}"
      FOUND=1
    fi
  done
done < <(git ls-files)

if [ "$FOUND" -eq 1 ]; then
  echo ""
  echo -e "${RED}╔══════════════════════════════════════════════╗${NC}"
  echo -e "${RED}║   PUSH BLOCKED — secrets found in repo.     ║${NC}"
  echo -e "${RED}║   Clean your git history before pushing.    ║${NC}"
  echo -e "${RED}╚══════════════════════════════════════════════╝${NC}"
  exit 1
fi

echo -e "${GREEN}✓ Security scan passed — pushing to GitHub.${NC}"
exit 0
